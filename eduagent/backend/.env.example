# 科大讯飞星火 API 配置
SPARK_API_KEY=your_spark_api_key_here
SPARK_API_SECRET=your_spark_api_secret_here
SPARK_APP_ID=your_app_id_here
SPARK_API_URL=wss://spark-api.xf-yun.com/v4.0/chat
SPARK_HTTP_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
SPARK_MODEL=x1

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./eduagent.db

# 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma_db

# 课程知识库路径
KNOWLEDGE_BASE_DIR=./data/ai_intro

# 安全配置
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true

# 前端地址（CORS）
FRONTEND_URL=http://localhost:5173
